# Copy this file to ".env" and fill in your real values.
# The real .env is git-ignored and must NEVER be committed or shared.
# In the cloud (GitHub Actions) these are stored as encrypted repository Secrets,
# not in this file.

TELEGRAM_BOT_TOKEN=put-your-botfather-token-here
TELEGRAM_CHAT_ID=put-your-numeric-chat-id-here

# Optional tuning (defaults are fine):
# OLX_PAGE_LIMIT=50
# MAX_NOTIFY_PER_FILTER=15
